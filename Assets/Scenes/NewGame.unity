  m_EditorClassIdentifier: Assembly-CSharp::GameManager
  dataBank:
  - answerQuestion: "Yaylac\u0131k"
    FuorAnswer:
    - Enra
    - Sahil
    - "Yaylac\u0131k"
    - Starbucks
    qustions: Sahneden sonra genellikle gidilen yer neresidir?
  - answerQuestion: "Yi\u011Fit"
    FuorAnswer:
    - "Yi\u011Fit"
    - Cavidan
    - Eren
    - Atacan
    qustions: "Hangisi hain bir ajand\u0131r?"
  - answerQuestion: "O\u011Fuzhan"
    FuorAnswer:
    - "O\u011Fuzhan"
    - Cavidan
    - Atacan
    - Eren
    qustions: "Olur day\u0131, Yapar\u0131z day\u0131,He day\u0131?"
  - answerQuestion: "Dile doland\u0131"
    FuorAnswer:
    - "\u015Eov ad\u0131"
    - "Dile doland\u0131"
    - Gizlilik
    - "\u015Eapka tak\u0131yoz"
    qustions: Neden "Ajan" kelimesi?
  - answerQuestion: Cliff Venue
    FuorAnswer:
    - RedRoxx
    - Sahne
    - Karga
    - Cliff Venue
    qustions: "Hangisi Ajanlar\u0131n sahne ald\u0131\u011F\u0131 mekanlardan de\u011Fildir?"
  - answerQuestion: "Sevmedi\u011Fi bi\u015Fey mi var?"
    FuorAnswer:
    - Lahmacun
    - Burger
    - Pizza
    - "Sevmedi\u011Fi bi\u015Fey mi var?"
    qustions: "Hangisi Yi\u011Fit'in sevdi\u011Fi bir yiyecek de\u011Fildir"
  - answerQuestion: Zakkum
    FuorAnswer:
    - "G\xFCl\u015Fen"
    - Murat Boz
    - Zakkum
    - "Serdar Orta\xE7"
    qustions: "Ajanlar\u0131n muhtemelen hi\xE7 \xE7almayaca\u011F\u0131 sanat\xE7\u0131
      hangisidir?"
  - answerQuestion: Pinhani
    FuorAnswer:
    - Redd
    - Pinhani
    - "Seksend\xF6rt"
    - Kaset
    qustions: "Ajanlar\u0131n en son birlikte gitti\u011Fi b\xFCy\xFCk konser hangisidir?"
  - answerQuestion: "Bal\u0131k"
    FuorAnswer:
    - Tavuk
    - Asperox
    - Ahtopot
    - "Bal\u0131k"
    qustions: "Hangisi ajanlardan birinin takma ismi de\u011Fildir?"
  - answerQuestion: Eren
    FuorAnswer:
    - Cavidan
    - Atacan
    - "O\u011Fuzhan"
    - Eren
    qustions: "Bu quizi haz\u0131rlayan ki\u015Fi hangi ajan\u0131n manitas\u0131d\u0131r?
      (Zor soru)"
  - answerQuestion: RedRoxx
    FuorAnswer:
    - Sahne
    - 'Sherlock '
    - Karga
    - RedRoxx
    qustions: "Ajanlar hangi mekanda Pazartesi ve Cuma g\xFCnleri sahne al\u0131yorlar?"
  - answerQuestion: Cavidan
    FuorAnswer:
    - Eren
    - Cavidan
    - Atacan
    - "O\u011Fuzhan"
    qustions: "Hangi ajan evli, mutlu, \xE7ocukludur?"
